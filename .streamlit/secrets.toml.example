# Copy to .streamlit/secrets.toml locally. On Streamlit Cloud: paste into App → Settings → Secrets.
# Never commit real secrets.toml to GitHub.

OPENAI_API_KEY = ""

# If you still get "authentication failed" (401), add billing at platform.openai.com (API is paid).
# Optional — only if your OpenAI account uses org / project scoping:
# OPENAI_ORGANIZATION = "org-xxxxxxxx"
# OPENAI_PROJECT = "proj_xxxxxxxx"

# --- Easiest: plain keys (username for login is always "demo") ---
PYSEED_DEMO_PASSWORD_HASH = "$2b$12$R52UkcUSenMG5B8Vq9aYFe8m15tbaLFC2Zy0jp5TE2N8uzlOvkRiO"
PYSEED_DEMO_NAME = "Demo Learner"
# Password for that hash: pyseed-demo
# New hash: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"

# --- Alternative: TOML section (same login: demo / pyseed-demo) ---
# [auth_users.demo]
# name = "Demo Learner"
# password_hash = "$2b$12$R52UkcUSenMG5B8Vq9aYFe8m15tbaLFC2Zy0jp5TE2N8uzlOvkRiO"
